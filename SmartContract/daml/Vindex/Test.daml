-- | Daml Script tests for Vindex. Covers every workflow path plus the voting models,
--   the money invariant, the overfund check, and the v2 BYOK liveness (stale-pending auto-accept).
--
-- Run: `daml test`
module Vindex.Test where

import Vindex
import Daml.Script
import DA.Time (RelTime, hours, days, addRelTime)
import DA.List (head)

-- daml.yaml init-script. Intentionally a no-op; `daml test` runs the test scripts below.
setup : Script ()
setup = pure ()

-- ---------------------------------------------------------------------------
-- Shared context + single-investor setup (proves the party-of-one code path)
-- ---------------------------------------------------------------------------

data Ctx = Ctx
  with
    i1 : Party
    worker : Party
    agent : Party
    ip : ContractId InvestorParty
    proj : ContractId Project

-- | Build a ready-to-run single-investor project (party of one) with the given milestones.
--   v2: no agent-fee args — the arbiter is BYOK / off-ledger.
setupSingle
  :  [MilestoneSpec] -> Decimal -> Decimal -> Script Ctx
setupSingle milestones budgetAmount commitmentRequired = do
  i1 <- allocateParty "Investor1"
  worker <- allocateParty "Worker"
  agent <- allocateParty "Agent"
  publicParty <- allocateParty "Public"
  let cfg = GovernanceConfig with
        maxInvestors = 3
        votingModel = SimpleMajority
        thresholdFraction = 0.5
        weighted = False
        quorumFraction = 0.5
        defaultReviewWindow = hours 24
  ip <- submit i1 $ createCmd (InvestorParty with
          admin = i1
          members = [i1]
          pending = []
          contributions = [Contribution with investor = i1, projectFunding = budgetAmount, weight = 1.0]
          config = cfg
          agent = agent)
  (posting, _) <- submit i1 $ exerciseCmd ip (SetupAndPost with
          postingId = "job-single"
          requirements = "build it"
          briefUri = ""
          budgetAmount = budgetAmount
          commitmentRequired = commitmentRequired
          maxRevisions = 5
          recruitmentMode = "INVITE_ONLY"
          eligibleWorkers = [partyToText worker]
          publicParty = publicParty)
  app <- submit worker $ exerciseCmd posting (Apply with applicant = worker, presentationHash = "p", presentationUri = "", contactLink = "l")
  now <- getTime
  prop <- submit i1 $ exerciseCmd ip (OpenProposal with purpose = "select", action = SelectWinner worker, deadline = addRelTime now (days 1))
  prop1 <- submit i1 $ exerciseCmd prop (CastProposalVote with voter = i1, vote = ACCEPT)
  mandate <- submit i1 $ exerciseCmd posting (SelectWorker with actor = i1, proposalCid = prop1, applicationCid = app)
  -- Worker authors the milestone plan (SOW); investor approves it -> Project.
  plan <- submit worker $ exerciseCmd mandate (ProposePlan with milestones = milestones, maxSubmissions = 5)
  proj <- submit i1 $ exerciseCmd plan (ApprovePlan with actor = i1)
  pure (Ctx with i1, worker, agent, ip, proj)

oneMilestone : Bool -> Decimal -> Decimal -> RelTime -> MilestoneSpec
oneMilestone isFinal payment p workerWindow = MilestoneSpec with
  deliverablesHash = "deliv"
  payment = payment
  workerWindow = workerWindow
  reviewWindow = hours 24
  violationPct = p
  isFinal = isFinal

-- v2 money invariant: budget + commitment + paidOut == initial (no agent-fee vault).
assertInvariant : Settlement -> Decimal -> Script ()
assertInvariant s initialTotal =
  assertMsg "money invariant: budget + commitment + paidOut == initial"
    (s.refundedBudget + s.refundedCommitment + s.totalPaidOut == initialTotal)

-- ---------------------------------------------------------------------------
-- 1. Multi-investor happy path: formation, selection vote, accept, auto-accept, invariant
-- ---------------------------------------------------------------------------

testHappyPathMulti : Script ()
testHappyPathMulti = do
  i1 <- allocateParty "Investor1"
  i2 <- allocateParty "Investor2"
  i3 <- allocateParty "Investor3"
  worker <- allocateParty "Worker"
  other <- allocateParty "Worker"
  agent <- allocateParty "Agent"
  publicParty <- allocateParty "Public"
  let cfg = GovernanceConfig with
        maxInvestors = 5
        votingModel = SimpleMajority
        thresholdFraction = 0.5
        weighted = False
        quorumFraction = 0.5
        defaultReviewWindow = hours 24
  let mkC p = Contribution with investor = p, projectFunding = 1200.0, weight = 1.0
  -- Party formation via invite/accept (sequential).
  ip1 <- submit i1 $ createCmd (InvestorParty with admin = i1, members = [i1], pending = [], contributions = [mkC i1], config = cfg, agent = agent)
  inv2 <- submit i1 $ exerciseCmd ip1 (InviteInvestor with invitee = i2, proposedContribution = mkC i2)
  ip2 <- submit i2 $ exerciseCmd inv2 AcceptInvite
  inv3 <- submit i1 $ exerciseCmd ip2 (InviteInvestor with invitee = i3, proposedContribution = mkC i3)
  ip3 <- submit i3 $ exerciseCmd inv3 AcceptInvite
  let m1 = oneMilestone False 1000.0 0.1 (hours 48)
      m2 = oneMilestone True  2000.0 0.1 (hours 48)
  -- budget envelope 3600; the worker's plan requires 1000*1.1 + 2000*1.1 = 3300 (fits).
  (posting, _) <- submit i1 $ exerciseCmd ip3 (SetupAndPost with
          postingId = "job-multi", requirements = "Build X", briefUri = ""
          budgetAmount = 3600.0
          commitmentRequired = 500.0
          maxRevisions = 3
          recruitmentMode = "INVITE_ONLY"
          eligibleWorkers = [partyToText worker, partyToText other]
          publicParty = publicParty)
  -- Two private applications; applicants cannot see each other's.
  appW <- submit worker $ exerciseCmd posting (Apply with applicant = worker, presentationHash = "pW", presentationUri = "", contactLink = "lW")
  _appO <- submit other $ exerciseCmd posting (Apply with applicant = other, presentationHash = "pO", presentationUri = "", contactLink = "lO")
  -- Worker selection by governance vote (2/3 ACCEPT >= 0.5 * 3).
  now <- getTime
  sp <- submit i1 $ exerciseCmd ip3 (OpenProposal with purpose = "select", action = SelectWinner worker, deadline = addRelTime now (days 1))
  sp1 <- submit i1 $ exerciseCmd sp (CastProposalVote with voter = i1, vote = ACCEPT)
  sp2 <- submit i2 $ exerciseCmd sp1 (CastProposalVote with voter = i2, vote = ACCEPT)
  mandate <- submit i1 $ exerciseCmd posting (SelectWorker with actor = i1, proposalCid = sp2, applicationCid = appW)
  -- Worker authors the plan; investor approves it -> Project.
  plan <- submit worker $ exerciseCmd mandate (ProposePlan with milestones = [m1, m2], maxSubmissions = 3)
  proj0 <- submit i1 $ exerciseCmd plan (ApprovePlan with actor = i1)
  -- Milestone 1: submit + ACCEPT vote (2/3) -> release + advance.
  proj1 <- submit worker $ exerciseCmd proj0 (SubmitMilestone with deliverableHash = "d1", deliverableUri = "")
  r1 <- nextReview i1
  r1a <- submit i1 $ exerciseCmd r1 (CastVote with voter = i1, vote = ACCEPT)
  r1b <- submit i2 $ exerciseCmd r1a (CastVote with voter = i2, vote = ACCEPT)
  Some proj2 <- submit i1 $ exerciseCmd proj1 (FinalizeReview with actor = i1, reviewCid = r1b)
  -- Milestone 2 (final): submit, then AUTO-ACCEPT on inactivity (no votes, deadline passes).
  proj3 <- submit worker $ exerciseCmd proj2 (SubmitMilestone with deliverableHash = "d2", deliverableUri = "")
  r2 <- nextReview i1
  passTime (hours 25)
  None <- submit i1 $ exerciseCmd proj3 (FinalizeReview with actor = i1, reviewCid = r2)
  -- Money invariant after completion.
  s <- onlySettlement i1
  -- initial = budget 3600 + commitment 500 = 4100
  assertInvariant s 4100.0
  pure ()

-- ---------------------------------------------------------------------------
-- 2. Overfund check rejects an underfunded budget
-- ---------------------------------------------------------------------------

testOverfundRejected : Script ()
testOverfundRejected = do
  i1 <- allocateParty "Investor1"
  worker <- allocateParty "Worker"
  agent <- allocateParty "Agent"
  publicParty <- allocateParty "Public"
  let cfg = GovernanceConfig with
        maxInvestors = 3, votingModel = SimpleMajority, thresholdFraction = 0.5
        weighted = False, quorumFraction = 0.5, defaultReviewWindow = hours 24
  ip <- submit i1 $ createCmd (InvestorParty with
          admin = i1, members = [i1], pending = []
          contributions = [Contribution with investor = i1, projectFunding = 1000.0, weight = 1.0]
          config = cfg, agent = agent)
  -- Budget envelope 1000 is funded fine; the overfund check is at plan approval.
  (posting, _) <- submit i1 $ exerciseCmd ip (SetupAndPost with
          postingId = "job-overfund", requirements = "x", briefUri = ""
          budgetAmount = 1000.0
          commitmentRequired = 100.0
          maxRevisions = 3
          recruitmentMode = "INVITE_ONLY"
          eligibleWorkers = [partyToText worker]
          publicParty = publicParty)
  app <- submit worker $ exerciseCmd posting (Apply with applicant = worker, presentationHash = "p", presentationUri = "", contactLink = "l")
  now <- getTime
  prop <- submit i1 $ exerciseCmd ip (OpenProposal with purpose = "select", action = SelectWinner worker, deadline = addRelTime now (days 1))
  prop1 <- submit i1 $ exerciseCmd prop (CastProposalVote with voter = i1, vote = ACCEPT)
  mandate <- submit i1 $ exerciseCmd posting (SelectWorker with actor = i1, proposalCid = prop1, applicationCid = app)
  -- Worker proposes a plan requiring 1100 (1000*1.1) > 1000 envelope -> approval must fail.
  plan <- submit worker $ exerciseCmd mandate (ProposePlan with milestones = [oneMilestone True 1000.0 0.1 (hours 1)], maxSubmissions = 1)
  submitMustFail i1 $ exerciseCmd plan (ApprovePlan with actor = i1)
  pure ()

-- ---------------------------------------------------------------------------
-- 3. Voting models: simple majority, super majority, weighted (70/30) — exact thresholds
-- ---------------------------------------------------------------------------

testVotingModels : Script ()
testVotingModels = do
  pA <- allocateParty "A"
  pB <- allocateParty "B"
  pC <- allocateParty "C"
  let eq = [ Contribution with investor = pA, projectFunding = 0.0, weight = 1.0
           , Contribution with investor = pB, projectFunding = 0.0, weight = 1.0
           , Contribution with investor = pC, projectFunding = 0.0, weight = 1.0 ]
  let simple = GovernanceConfig with
        maxInvestors = 5, votingModel = SimpleMajority, thresholdFraction = 0.5
        weighted = False, quorumFraction = 0.5, defaultReviewWindow = hours 1
  assertMsg "simple: 2/3 passes" (proposalPassed simple eq [(pA, ACCEPT), (pB, ACCEPT)])
  assertMsg "simple: 1/3 fails (quorum + threshold)" (not (proposalPassed simple eq [(pA, ACCEPT)]))
  let superm = simple with votingModel = SuperMajority, thresholdFraction = 0.66
  assertMsg "super: 2/3 (0.667) passes" (proposalPassed superm eq [(pA, ACCEPT), (pB, ACCEPT)])
  assertMsg "super: 1/3 fails" (not (proposalPassed superm eq [(pA, ACCEPT)]))
  let wcs = [ Contribution with investor = pA, projectFunding = 0.0, weight = 70.0
            , Contribution with investor = pB, projectFunding = 0.0, weight = 30.0 ]
      weighted = GovernanceConfig with
        maxInvestors = 5, votingModel = Weighted, thresholdFraction = 0.66
        weighted = True, quorumFraction = 0.0, defaultReviewWindow = hours 1
  assertMsg "weighted: 70 alone passes (>= 0.66*100)" (proposalPassed weighted wcs [(pA, ACCEPT)])
  assertMsg "weighted: 30 alone fails" (not (proposalPassed weighted wcs [(pB, ACCEPT)]))
  pure ()

-- ---------------------------------------------------------------------------
-- 4. Valid rejection -> revision -> resubmit -> accept (single investor)
-- ---------------------------------------------------------------------------

testValidRejectionRevision : Script ()
testValidRejectionRevision = do
  ctx <- setupSingle [oneMilestone True 1000.0 0.1 (hours 48)] 1200.0 500.0
  proj1 <- submit ctx.worker $ exerciseCmd ctx.proj (SubmitMilestone with deliverableHash = "h1", deliverableUri = "")
  r0 <- nextReview ctx.i1
  r1 <- submit ctx.i1 $ exerciseCmd r0 (CastVote with voter = ctx.i1, vote = REJECT)
  r2 <- submit ctx.i1 $ exerciseCmd r1 (SetRejectionReasons with actor = ctx.i1, reasons = ["incomplete feature"])
  Some proj2 <- submit ctx.i1 $ exerciseCmd proj1 (FinalizeReview with actor = ctx.i1, reviewCid = r2)
  -- Agent rules the rejection VALID -> worker revises.
  Some proj3 <- submit ctx.agent $ exerciseCmd proj2 (AgentVerdict with rejectionValid = True)
  proj4 <- submit ctx.worker $ exerciseCmd proj3 (SubmitMilestone with deliverableHash = "h2", deliverableUri = "")
  rr <- nextReview ctx.i1
  rr1 <- submit ctx.i1 $ exerciseCmd rr (CastVote with voter = ctx.i1, vote = ACCEPT)
  None <- submit ctx.i1 $ exerciseCmd proj4 (FinalizeReview with actor = ctx.i1, reviewCid = rr1)
  s <- onlySettlement ctx.i1
  -- initial = 1200 + 500 = 1700
  assertInvariant s 1700.0
  pure ()

-- ---------------------------------------------------------------------------
-- 5. Invalid rejection -> investor-party violation (penalty + full payment to worker)
-- ---------------------------------------------------------------------------

testInvestorViolation : Script ()
testInvestorViolation = do
  ctx <- setupSingle [oneMilestone True 1000.0 0.1 (hours 48)] 1200.0 500.0
  proj1 <- submit ctx.worker $ exerciseCmd ctx.proj (SubmitMilestone with deliverableHash = "h1", deliverableUri = "")
  r0 <- nextReview ctx.i1
  r1 <- submit ctx.i1 $ exerciseCmd r0 (CastVote with voter = ctx.i1, vote = REJECT)
  r2 <- submit ctx.i1 $ exerciseCmd r1 (SetRejectionReasons with actor = ctx.i1, reasons = ["bad faith nitpick"])
  Some proj2 <- submit ctx.i1 $ exerciseCmd proj1 (FinalizeReview with actor = ctx.i1, reviewCid = r2)
  -- Agent rules the rejection INVALID -> investor-party violation; worker gets 1000 + 100 bonus.
  None <- submit ctx.agent $ exerciseCmd proj2 (AgentVerdict with rejectionValid = False)
  s <- onlySettlement ctx.i1
  -- v2: no agent op fee, so paidOut = 1100 (release + bonus)
  assertMsg "worker received payment + penalty bonus" (s.totalPaidOut == 1100.0)
  assertInvariant s 1700.0
  pure ()

-- ---------------------------------------------------------------------------
-- 6. Worker violation -> failure-stop by governance vote (penalty capped at commitment)
-- ---------------------------------------------------------------------------

testWorkerViolationStop : Script ()
testWorkerViolationStop = do
  let m1 = oneMilestone False 1000.0 0.2 (hours 1)
      m2 = oneMilestone True  1000.0 0.2 (hours 1)
  ctx <- setupSingle [m1, m2] 2400.0 500.0
  passTime (hours 2)
  projF <- submit ctx.i1 $ exerciseCmd ctx.proj (WorkerViolation with actor = ctx.i1)
  now <- getTime
  sp <- submit ctx.i1 $ exerciseCmd ctx.ip (OpenProposal with purpose = "stop", action = ResolveStop, deadline = addRelTime now (days 1))
  sp1 <- submit ctx.i1 $ exerciseCmd sp (CastProposalVote with voter = ctx.i1, vote = ACCEPT)
  None <- submit ctx.i1 $ exerciseCmd projF (ResolveAfterViolation with actor = ctx.i1, proposalCid = sp1)
  s <- onlySettlement ctx.i1
  -- penalty = min(1000*0.2, 500) = 200; commitment refund 300; paidOut 200
  assertMsg "commitment penalised by 200" (s.refundedCommitment == 300.0)
  assertInvariant s 2900.0   -- 2400 + 500
  pure ()

-- ---------------------------------------------------------------------------
-- 7. BYOK liveness: a RejPending dispute the Agent never rules on AUTO-ACCEPTS after the
--    verdict deadline, paying the worker (an unsubstantiated rejection loses).
-- ---------------------------------------------------------------------------

testStalePendingAutoAccept : Script ()
testStalePendingAutoAccept = do
  ctx <- setupSingle [oneMilestone True 1000.0 0.1 (hours 48)] 1200.0 500.0
  proj1 <- submit ctx.worker $ exerciseCmd ctx.proj (SubmitMilestone with deliverableHash = "h1", deliverableUri = "")
  r0 <- nextReview ctx.i1
  r1 <- submit ctx.i1 $ exerciseCmd r0 (CastVote with voter = ctx.i1, vote = REJECT)
  r2 <- submit ctx.i1 $ exerciseCmd r1 (SetRejectionReasons with actor = ctx.i1, reasons = ["disputed but never arbitrated"])
  Some proj2 <- submit ctx.i1 $ exerciseCmd proj1 (FinalizeReview with actor = ctx.i1, reviewCid = r2)
  -- Agent never rules; the verdict deadline (finalize time + reviewWindow = 24h) passes.
  passTime (hours 25)
  -- Worker triggers the stale-pending auto-accept -> paid the milestone, no penalty.
  None <- submit ctx.worker $ exerciseCmd proj2 (ResolveStalePending with actor = ctx.worker)
  s <- onlySettlement ctx.i1
  assertMsg "stale pending auto-accepts and pays the worker the milestone" (s.totalPaidOut == 1000.0)
  assertInvariant s 1700.0
  pure ()

-- ---------------------------------------------------------------------------
-- 8. Edit and Take Down Posting (single investor)
-- ---------------------------------------------------------------------------

testEditAndTakeDownPosting : Script ()
testEditAndTakeDownPosting = do
  i1 <- allocateParty "Investor1"
  worker <- allocateParty "Worker"
  agent <- allocateParty "Agent"
  publicParty <- allocateParty "Public"
  let cfg = GovernanceConfig with
        maxInvestors = 3
        votingModel = SimpleMajority
        thresholdFraction = 0.5
        weighted = False
        quorumFraction = 0.5
        defaultReviewWindow = hours 24
  ip <- submit i1 $ createCmd (InvestorParty with
          admin = i1
          members = [i1]
          pending = []
          contributions = [Contribution with investor = i1, projectFunding = 1200.0, weight = 1.0]
          config = cfg
          agent = agent)
  (posting, budget) <- submit i1 $ exerciseCmd ip (SetupAndPost with
          postingId = "job-edit", requirements = "original requirements"
          briefUri = ""
          budgetAmount = 1200.0
          commitmentRequired = 500.0
          maxRevisions = 3
          recruitmentMode = "INVITE_ONLY"
          eligibleWorkers = [partyToText worker]
          publicParty = publicParty)

  -- Edit description
  postingUpdated <- submit i1 $ exerciseCmd posting (EditPostingDescription with actor = i1, newRequirements = "updated requirements")
  p <- queryContractId @ProjectPosting i1 postingUpdated
  case p of
    Some post -> assertMsg "requirements should be updated" (post.requirements == "updated requirements")
    None -> abort "posting should exist"

  -- Take down posting
  submit i1 $ exerciseCmd postingUpdated (TakeDownPosting with actor = i1)

  -- Check that posting is archived and the budget vault is settled
  postingQuery <- queryContractId @ProjectPosting i1 postingUpdated
  case postingQuery of
    Some _ -> abort "posting should be archived"
    None -> pure ()

  budgetQuery <- queryContractId @AssetVault i1 budget
  case budgetQuery of
    Some _ -> abort "budget vault should be settled (archived)"
    None -> pure ()

  pure ()

-- ---------------------------------------------------------------------------
-- 9. Propose plan again / replace plan (single investor)
-- ---------------------------------------------------------------------------

testProposePlanAgain : Script ()
testProposePlanAgain = do
  i1 <- allocateParty "Investor1"
  worker <- allocateParty "Worker"
  agent <- allocateParty "Agent"
  publicParty <- allocateParty "Public"
  let cfg = GovernanceConfig with
        maxInvestors = 3
        votingModel = SimpleMajority
        thresholdFraction = 0.5
        weighted = False
        quorumFraction = 0.5
        defaultReviewWindow = hours 24
  ip <- submit i1 $ createCmd (InvestorParty with
          admin = i1
          members = [i1]
          pending = []
          contributions = [Contribution with investor = i1, projectFunding = 2000.0, weight = 1.0]
          config = cfg
          agent = agent)
  (posting, _) <- submit i1 $ exerciseCmd ip (SetupAndPost with
          postingId = "job-propose", requirements = "build it"
          briefUri = ""
          budgetAmount = 2000.0
          commitmentRequired = 500.0
          maxRevisions = 5
          recruitmentMode = "INVITE_ONLY"
          eligibleWorkers = [partyToText worker]
          publicParty = publicParty)
  app <- submit worker $ exerciseCmd posting (Apply with applicant = worker, presentationHash = "p", presentationUri = "", contactLink = "l")
  now <- getTime
  prop <- submit i1 $ exerciseCmd ip (OpenProposal with purpose = "select", action = SelectWinner worker, deadline = addRelTime now (days 1))
  prop1 <- submit i1 $ exerciseCmd prop (CastProposalVote with voter = i1, vote = ACCEPT)
  mandate <- submit i1 $ exerciseCmd posting (SelectWorker with actor = i1, proposalCid = prop1, applicationCid = app)

  -- First plan submission
  plan1 <- submit worker $ exerciseCmd mandate (ProposePlan with milestones = [oneMilestone True 1000.0 0.1 (hours 48)], maxSubmissions = 5)

  -- Propose plan again (replaces first plan)
  plan2 <- submit worker $ exerciseCmd plan1 (ProposePlanAgain with newMilestones = [oneMilestone True 1500.0 0.1 (hours 48)], newMaxSubmissions = 3)

  -- Verify plan1 is archived and plan2 is active
  plan1Query <- queryContractId @WorkPlan worker plan1
  case plan1Query of
    Some _ -> abort "plan1 should be archived"
    None -> pure ()

  plan2Query <- queryContractId @WorkPlan worker plan2
  case plan2Query of
    Some wp -> do
      assertMsg "plan2 max submissions should be 3" (wp.maxSubmissions == 3)
      let m = head wp.milestones
      assertMsg "plan2 payment should be 1500" (m.payment == 1500.0)
    None -> abort "plan2 should exist"

  pure ()

-- ---------------------------------------------------------------------------
-- 10. Duplicate Application Prevention
-- ---------------------------------------------------------------------------

testDuplicateApplyRejected : Script ()
testDuplicateApplyRejected = do
  i1 <- allocateParty "Investor1"
  worker <- allocateParty "Worker"
  agent <- allocateParty "Agent"
  publicParty <- allocateParty "Public"
  let cfg = GovernanceConfig with
        maxInvestors = 3
        votingModel = SimpleMajority
        thresholdFraction = 0.5
        weighted = False
        quorumFraction = 0.5
        defaultReviewWindow = hours 24
  ip <- submit i1 $ createCmd (InvestorParty with
          admin = i1
          members = [i1]
          pending = []
          contributions = [Contribution with investor = i1, projectFunding = 1200.0, weight = 1.0]
          config = cfg
          agent = agent)
  (posting, _) <- submit i1 $ exerciseCmd ip (SetupAndPost with
          postingId = "job-duplicate"
          requirements = "original requirements"
          briefUri = ""
          budgetAmount = 1200.0
          commitmentRequired = 500.0
          maxRevisions = 3
          recruitmentMode = "INVITE_ONLY"
          eligibleWorkers = [partyToText worker]
          publicParty = publicParty)

  -- First application succeeds
  _ <- submit worker $ exerciseCmd posting (Apply with applicant = worker, presentationHash = "p1", presentationUri = "", contactLink = "l1")

  -- Second application from same worker fails
  submitMustFail worker $ exerciseCmd posting (Apply with applicant = worker, presentationHash = "p2", presentationUri = "", contactLink = "l2")
  pure ()

-- ---------------------------------------------------------------------------
-- 11. Dynamic Prefix-based Worker Validation
-- ---------------------------------------------------------------------------

testDynamicPrefixApply : Script ()
testDynamicPrefixApply = do
  i1 <- allocateParty "Investor1"
  worker <- allocateParty "Worker"
  -- worker2 is allocated as "Worker" but is a separate party (different hash)
  worker2 <- allocateParty "Worker"
  agent <- allocateParty "Agent"
  publicParty <- allocateParty "Public"
  let cfg = GovernanceConfig with
        maxInvestors = 3
        votingModel = SimpleMajority
        thresholdFraction = 0.5
        weighted = False
        quorumFraction = 0.5
        defaultReviewWindow = hours 24
  ip <- submit i1 $ createCmd (InvestorParty with
          admin = i1
          members = [i1]
          pending = []
          contributions = [Contribution with investor = i1, projectFunding = 1200.0, weight = 1.0]
          config = cfg
          agent = agent)
  -- 1. Invite Only Pool (isOpenPool = False)
  (posting1, _) <- submit i1 $ exerciseCmd ip (SetupAndPost with
          postingId = "job-invite-only"
          requirements = "test"
          briefUri = ""
          budgetAmount = 1200.0
          commitmentRequired = 500.0
          maxRevisions = 3
          recruitmentMode = "INVITE_ONLY"
          eligibleWorkers = [partyToText worker, partyToText i1] -- worker is in the pool, worker2 is NOT
          publicParty = publicParty)

  -- worker (exact match) -> Succeeds
  _ <- submit worker $ exerciseCmd posting1 (Apply with applicant = worker, presentationHash = "p1", presentationUri = "", contactLink = "l1")
  -- worker2 (different hash, not in pool) -> Fails
  submitMustFail worker2 $ exerciseCmd posting1 (Apply with applicant = worker2, presentationHash = "p2", presentationUri = "", contactLink = "l2")

  -- 2. Open Pool (isOpenPool = True)
  (posting2, _) <- submit i1 $ exerciseCmd ip (SetupAndPost with
          postingId = "job-open-pool"
          requirements = "test"
          briefUri = ""
          budgetAmount = 1200.0
          commitmentRequired = 500.0
          maxRevisions = 3
          recruitmentMode = "OPEN_POOL"
          eligibleWorkers = ["Worker::*"]
          publicParty = publicParty)

  -- Both worker and worker2 have display name "Worker" (with different hashes) and can apply in Open Pool
  _ <- submitMulti [worker] [publicParty] $
        exerciseCmd posting2 (Apply with applicant = worker, presentationHash = "p1", presentationUri = "", contactLink = "l1")
  _ <- submitMulti [worker2] [publicParty] $
        exerciseCmd posting2 (Apply with applicant = worker2, presentationHash = "p2", presentationUri = "", contactLink = "l2")

  -- i1 is in the pool but starts with "Investor1" (not "Worker") -> Fails in both
  submitMultiMustFail [i1] [publicParty] $
    exerciseCmd posting2 (Apply with applicant = i1, presentationHash = "p3", presentationUri = "", contactLink = "l3")
  pure ()

-- ---------------------------------------------------------------------------
-- Query helpers
-- ---------------------------------------------------------------------------

-- | The single active MilestoneReview visible to a member (exactly one per open cycle).
nextReview : Party -> Script (ContractId MilestoneReview)
nextReview p = do
  rs <- query @MilestoneReview p
  pure (fst (head rs))

-- | The single Settlement visible to a member after completion/stop.
onlySettlement : Party -> Script Settlement
onlySettlement p = do
  ss <- query @Settlement p
  pure (snd (head ss))
