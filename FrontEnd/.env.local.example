# ── Verdix dapp → Canton participant ────────────────────────────────────────
# Copy to `.env.local` and fill in for your HOSTED participant.

# Client: the participant's HTTP JSON Ledger API (NOT the gRPC port).
# `@daml/ledger` needs the JSON API; if your participant only exposes gRPC,
# run a `daml json-api` sidecar in front of it and point these at the sidecar.
NEXT_PUBLIC_LEDGER_HTTP_URL=https://your-participant.example.com/
NEXT_PUBLIC_LEDGER_WS_URL=wss://your-participant.example.com/
NEXT_PUBLIC_LEDGER_RECONNECT_MS=30000

# Real allocated party ids on that participant (prefill the connect screen).
NEXT_PUBLIC_PARTY_INVESTOR=Investor::1220...
NEXT_PUBLIC_PARTY_WORKER=Worker::1220...
NEXT_PUBLIC_PARTY_AGENT=Agent::1220...

# ── Server-side token issuance (/api/daml-token) ────────────────────────────
# hosted = use a real participant token (production). dev = HS256 for local sandbox.
DAML_AUTH_MODE=hosted

# hosted, Option A: a pre-issued ledger-API JWT (simplest for a demo).
DAML_HOSTED_TOKEN=

# hosted, Option B: OIDC client-credentials exchange (leave Option A blank to use this).
DAML_OIDC_TOKEN_URL=
DAML_OIDC_CLIENT_ID=
DAML_OIDC_CLIENT_SECRET=
DAML_OIDC_AUDIENCE=
DAML_OIDC_SCOPE=

# ── Local dev only (DAML_AUTH_MODE=dev) ─────────────────────────────────────
# For a local sandbox started with: daml sandbox --auth-jwt-hs256-unsafe=<secret>
DAML_JWT_SECRET=secret
DAML_LEDGER_ID=sandbox
