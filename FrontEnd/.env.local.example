# ── Verdix dapp → Canton participant ────────────────────────────────────────
# Copy to `.env.local` and fill in for your HOSTED participant.

# Client: the participant's HTTP JSON Ledger API (NOT the gRPC port).
# `@daml/ledger` needs the JSON API; if your participant only exposes gRPC,
# run a `daml json-api` sidecar in front of it and point these at the sidecar.
NEXT_PUBLIC_LEDGER_HTTP_URL=https://your-participant.example.com/
NEXT_PUBLIC_LEDGER_WS_URL=wss://your-participant.example.com/
NEXT_PUBLIC_LEDGER_RECONNECT_MS=30000

# Real allocated party ids on that participant (prefill the connect screen).
NEXT_PUBLIC_PARTY_INVESTOR=Investor::1220...
NEXT_PUBLIC_PARTY_WORKER=Worker::1220...
NEXT_PUBLIC_PARTY_AGENT=Agent::1220...

# Open-job audience: the registered worker parties a new posting is published to (they become
# observers and are the ones allowed to apply). The investor does NOT hand-pick a winner — the
# winner is chosen later by governance vote among the applicants. Comma-separated; if unset it
# falls back to NEXT_PUBLIC_PARTY_WORKER. Add more parties here to demo multiple applicants.
# NEXT_PUBLIC_WORKER_POOL=Worker::1220...,Worker2::1220...,Worker3::1220...

# ── Server-side token issuance (/api/daml-token) ────────────────────────────
# hosted = use a real participant token (production). dev = HS256 for local sandbox.
DAML_AUTH_MODE=hosted

# hosted, Option A: a pre-issued ledger-API JWT (simplest for a demo).
DAML_HOSTED_TOKEN=

# hosted, Option B: OIDC client-credentials exchange (leave Option A blank to use this).
DAML_OIDC_TOKEN_URL=
DAML_OIDC_CLIENT_ID=
DAML_OIDC_CLIENT_SECRET=
DAML_OIDC_AUDIENCE=
DAML_OIDC_SCOPE=

# ── Local dev only (DAML_AUTH_MODE=dev) ─────────────────────────────────────
# For a local sandbox started with: daml sandbox --auth-jwt-hs256-unsafe=<secret>
DAML_JWT_SECRET=secret
DAML_LEDGER_ID=sandbox

# ── AI arbitration agent (OpenRouter) — server-side only, key never reaches browser ──
# The Agent party is an oracle: the AI runs off-ledger in /api/agent-verdict (via OpenRouter, an
# OpenAI-compatible gateway), checking the worker's submission against the project to-do list +
# the investor's rejection reasons, and recommends a verdict the Agent then writes on-ledger via
# Project.AgentVerdict.
OPENROUTER_API_KEY=
# Any model slug from https://openrouter.ai/models (defaults to anthropic/claude-3.5-sonnet).
# OPENROUTER_MODEL=anthropic/claude-3.5-sonnet
# Optional attribution shown in the OpenRouter dashboard.
# OPENROUTER_SITE_URL=http://localhost:3000

# ── Off-ledger file storage (IPFS via Pinata) ───────────────────────────────
# PINATA_JWT must be a key WITH the pinFileToIPFS scope (or Admin), else uploads 403 with
# NO_SCOPES_FOUND and the app falls back to non-retrievable local- CIDs.
PINATA_JWT=
# Use your DEDICATED gateway (Pinata dashboard → Gateways), e.g. https://your-name.mypinata.cloud
# Server-side fetch (AI agent) uses PINATA_GATEWAY; the browser "view" links use NEXT_PUBLIC_IPFS_GATEWAY.
PINATA_GATEWAY=https://gateway.pinata.cloud
NEXT_PUBLIC_IPFS_GATEWAY=https://gateway.pinata.cloud
# Only if your dedicated gateway has access controls (Gateways → your gateway → Access Controls).
# PINATA_GATEWAY_TOKEN=
